{
  "name": "crm-base",
  "version": "0.1.0",
  "private": true,
  "description": "White-label CRM monorepo built with Turborepo, Next.js, Fastify and TypeScript.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@crm-base/config": "workspace:*",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "packageExtensions": {
      "@hookform/resolvers@*": {
        "peerDependencies": {
          "zod": "3.23.8"
        }
      }
    }
  }
}