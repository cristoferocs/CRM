# APP
CLIENT_NAME="Cliente Exemplo"
CLIENT_SLUG="cliente-exemplo"
APP_URL="http://localhost:3000"
NODE_ENV="development"
PORT=3333

# TIER
# Valores possiveis: starter | growth | enterprise
# starter=Neon+Upstash, growth=CloudSQL+Upstash, enterprise=CloudSQL HA+Memorystore
INFRA_TIER="starter"

# GCP
GCP_PROJECT_ID=""
GCP_REGION="us-central1"

# DATABASE
# DATABASE_URL aponta para Neon no tier starter e Cloud SQL nos demais.
DATABASE_URL="postgresql://user:password@localhost:5432/crm_base"
NEON_DB_URL="postgresql://user:password@ep-example.neon.tech/crm_base?sslmode=require"

# REDIS
# REDIS_URL aponta para Upstash nos tiers starter/growth e Memorystore no enterprise.
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_URL="rediss://default:token@example.upstash.io:6379"

# FIREBASE AUTH
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# DEFAULT PLATFORM SUPER ADMIN
# Auto-provisionado em toda organizacao criada. O usuario eh criado no Firebase
# Auth (se as credenciais admin estiverem configuradas) e tambem como User
# SUPER_ADMIN no DB de cada novo cliente.
# OBRIGATORIO: preencha com seus dados reais antes de executar o seed.
DEFAULT_SUPER_ADMIN_EMAIL=""
DEFAULT_SUPER_ADMIN_PASSWORD=""
DEFAULT_SUPER_ADMIN_NAME=""

# WHATSAPP EVOLUTION API
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""

# WHATSAPP OFICIAL
WHATSAPP_OFFICIAL_TOKEN=""
WHATSAPP_PHONE_ID=""
WHATSAPP_VERIFY_TOKEN=""

# META
META_APP_ID=""
META_ACCESS_TOKEN=""
META_VERIFY_TOKEN=""
META_PIXEL_ID=""
META_CONVERSIONS_API_TOKEN=""

# GOOGLE ADS
GOOGLE_ADS_CUSTOMER_ID=""
GOOGLE_ADS_DEVELOPER_TOKEN=""

# MERCADO PAGO
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# STRIPE
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# PAYPAL
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# INFINITYPAY
INFINITYPAY_API_KEY=""

# STONE
STONE_CLIENT_ID=""
STONE_CLIENT_SECRET=""

# EMAIL
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
IMAP_HOST=""
IMAP_PORT=993

# JWT
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# STORAGE
# Uploads vao direto ao Storage via Signed URL; a API nunca ve os bytes.
GCS_BUCKET=""
GCS_SIGNED_URL_EXPIRY=900

# IA - PROVEDOR ATIVO
# Valores possiveis: google | anthropic | openai | ollama
# Trocar este valor muda o provedor sem alterar nenhuma linha de codigo.
AI_PROVIDER="google"

# IA - GOOGLE VERTEX AI
# Provedor padrao; dados ficam no GCP do proprio cliente.
GOOGLE_VERTEX_PROJECT=""
GOOGLE_VERTEX_LOCATION="us-central1"
GOOGLE_VERTEX_MODEL="gemini-1.5-pro"
GOOGLE_VERTEX_EMBEDDING_MODEL="text-embedding-004"
GOOGLE_APPLICATION_CREDENTIALS=""

# IA - ANTHROPIC CLAUDE
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# IA - OPENAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# IA - OLLAMA LOCAL
# Para modelos rodando em servidor proprio do cliente (zero custo por token).
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# IA - CONFIGURACOES GERAIS
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.3
# Valores possiveis: pgvector | vertex
# pgvector roda no proprio PostgreSQL (gratuito, tiers starter/growth), vertex usa Vertex AI Vector Search (tier enterprise, escala para milhoes de vetores).
VECTOR_SEARCH_PROVIDER="pgvector"

# GOOGLE WORKSPACE OAuth2
# OAuth2 unico para Calendar, Drive, Gmail e Meet.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3333/auth/google/callback"

# GOOGLE CALENDAR
GOOGLE_CALENDAR_ENABLED=true

# GOOGLE DRIVE
GOOGLE_DRIVE_ENABLED=true

# KNOWLEDGE BASE
# Controla como documentos sao quebrados em chunks para indexacao vetorial.
KB_CHUNK_SIZE=1000
KB_CHUNK_OVERLAP=200
KB_MAX_RESULTS=5