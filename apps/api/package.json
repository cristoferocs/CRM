{
  "name": "@crm-base/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsup src/server.ts --format esm --target es2022 --dts --sourcemap --clean",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-s01": "npx tsx prisma/seeds/s01-foundation.ts",
    "db:seed-s02": "npx tsx prisma/seeds/s02-knowledge.ts",
    "db:seed-s03": "npx tsx prisma/seeds/s03-agents.ts",
    "db:seed-s04": "npx tsx prisma/seeds/s04-pipelines.ts",
    "db:seed-s05": "npx tsx prisma/seeds/s05-contacts.ts",
    "db:seed-s06": "npx tsx prisma/seeds/s06-deals.ts",
    "db:seed-s07": "npx tsx prisma/seeds/s07-conversations.ts",
    "db:seed-s08": "npx tsx prisma/seeds/s08-payments-insights.ts",
    "db:seed-s09": "npx tsx prisma/seeds/s09-activities-audit.ts",
    "db:demo": "npx tsx prisma/seeds/run-demo.ts",
    "db:reset-demo": "npx prisma migrate reset --force && npx tsx prisma/seed.ts && npx tsx prisma/seeds/run-demo.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@crm-base/shared": "workspace:*",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/type-provider-zod": "^1.0.0",
    "@google-cloud/pubsub": "^4.11.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.16.0",
    "@google-cloud/vertexai": "^1.12.0",
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.53.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.9.0",
    "bullmq": "^5.52.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "firebase-admin": "^13.4.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "imapflow": "^1.0.184",
    "ioredis": "^5.6.1",
    "mercadopago": "^2.12.0",
    "nodemailer": "^6.10.1",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.1",
    "stripe": "^22.1.1",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@crm-base/config": "workspace:*",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.1.4"
  }
}