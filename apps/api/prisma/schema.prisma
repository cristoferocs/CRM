// =============================================================================
// CRM Base — Prisma Schema
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// =============================================================================
// ENUMS
// =============================================================================

enum Plan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  BRANCH_MANAGER
  SELLER
  SUPPORT
  VIEWER
}

enum ContactType {
  LEAD
  CUSTOMER
  PARTNER
}

enum ContactSource {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  EMAIL
  MANUAL
  IMPORT
  LANDING_PAGE
  ADS
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  WHATSAPP
  SYSTEM
}

enum ConversationChannel {
  WHATSAPP
  WHATSAPP_OFFICIAL
  INSTAGRAM
  FACEBOOK
  EMAIL
  INTERNAL
}

enum ConversationStatus {
  OPEN
  PENDING
  BOT
  RESOLVED
  SPAM
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  STICKER
  LOCATION
  TEMPLATE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum PaymentGateway {
  MERCADOPAGO
  STRIPE
  PAYPAL
  INFINITYPAY
  STONE
  PAGSEGURO
  ASAAS
}

enum PaymentType {
  SINGLE
  RECURRING
  SUBSCRIPTION
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum AutomationLogStatus {
  SUCCESS
  FAILED
  SKIPPED
}

enum AutomationTriggerEnum {
  CONTACT_CREATED
  CONTACT_UPDATED
  CONTACT_TAG_ADDED
  LEAD_SCORE_CHANGED
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  DEAL_WON
  DEAL_LOST
  DEAL_ROTTING
  MESSAGE_RECEIVED
  MESSAGE_KEYWORD
  CONVERSATION_OPENED
  CONVERSATION_RESOLVED
  TIME_DELAY
  SCHEDULED
  DATE_FIELD
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  PAYMENT_FAILED
  AGENT_HANDOFF
  AGENT_GOAL_ACHIEVED
}

enum NotificationType {
  MENTION
  DEAL_ASSIGNED
  DEAL_MOVED
  COMMENT_REPLY
  AGENT_HANDOFF
  PAYMENT_RECEIVED
  TASK_DUE
  AUTOMATION_FAILED
  LEAD_HOT
  ACHIEVEMENT_UNLOCKED
}

enum DocumentType {
  PROPOSAL
  CONTRACT
  NDA
  INVOICE
  ONBOARDING
  OTHER
}

enum DocumentStatus {
  DRAFT
  SENT
  PARTIALLY_SIGNED
  SIGNED
  EXPIRED
  CANCELLED
}

enum AchievementType {
  FIRST_DEAL_WON
  DEAL_STREAK
  REVENUE_MILESTONE
  FAST_CLOSER
  RESPONSE_MASTER
  OBJECTION_CRUSHER
  AI_DELEGATOR
  TOP_PERFORMER
  COMEBACK_KID
}

enum KnowledgeBaseType {
  DOCUMENT
  WEBSITE
  FAQ
  PRODUCT
  OBJECTION
  APPROACH
}

enum KnowledgeDocumentSourceType {
  PDF
  WEBSITE
  TEXT
  NOTION
  DRIVE
}

enum KnowledgeDocumentStatus {
  PENDING
  INDEXING
  INDEXED
  FAILED
}

enum AgentType {
  SALES
  SUPPORT
  SCHEDULER
  QUALIFICATION
  COLLECTIONS
  ONBOARDING
  CUSTOMER_SUCCESS
  RETENTION
  UPSELL
  CUSTOM
}

enum AgentStatus {
  DRAFT
  LEARNING
  REVIEW
  READY
  ACTIVE
  PAUSED
  RETIRED
}

enum AgentPhase {
  SETUP
  OBSERVATION
  LEARNING
  VALIDATION
  PRODUCTION
}

enum AIProvider {
  GOOGLE
  ANTHROPIC
  OPENAI
  OLLAMA
}

enum SessionStatus {
  ACTIVE
  THINKING
  WAITING_USER
  HANDOFF
  ENDED
}

enum AIInsightType {
  OBJECTION
  BEST_APPROACH
  PRODUCT_FEEDBACK
  SENTIMENT
  SUMMARY
  COACHING
}

enum AITrainingDataType {
  OBJECTION_RESPONSE
  SALES_APPROACH
  PRODUCT_INFO
  FAQ
}

enum PipelineType {
  SALES          // funil de vendas genérico
  PRODUCT        // por produto específico
  SERVICE        // por serviço específico
  CAMPAIGN       // por campanha de marketing/ads
  PARTNERSHIP    // parcerias e canais
  RENEWAL        // renovações e upsell
  RECRUITMENT    // RH e recrutamento
  CUSTOM         // propósito livre
}

enum PipelineVisibility {
  ALL            // todos da org
  DEPARTMENT     // apenas departamentos em allowedRoles
  ROLES          // apenas papéis específicos
}

enum StageType {
  REGULAR   // etapa normal
  ENTRY     // primeiro contato (pode ter múltiplas)
  NURTURING // nutrição/aquecimento
  DECISION  // etapa decisiva
  WON       // ganho
  LOST      // perdido
  ON_HOLD   // pausado/aguardando
}

enum StageAgentTrigger {
  MANUAL       // humano decide quando acionar o agente
  AUTO_ENTER   // agente acionado automaticamente ao entrar na etapa
  AUTO_ROTTING // agente acionado quando deal ficar parado
  SCHEDULED    // agente acionado em horário configurado
}

enum MovedByType {
  HUMAN      // vendedor humano
  AGENT      // super agente
  AUTOMATION // automação do sistema
  SYSTEM     // sistema (ex: rotting)
}

// =============================================================================
// ORGANIZATION
// =============================================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan                 Plan     @default(STARTER)
  settings             Json     @default("{}")
  whiteLabelSettings   Json?    // configurações de identidade visual
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users            User[]
  contacts         Contact[]
  deals            Deal[]
  conversations    Conversation[]
  departments      Department[]
  pipelines        Pipeline[]
  companies        Company[]
  payments         Payment[]
  webhooks         Webhook[]
  automations      Automation[]
  timeline         TimelineEvent[]
  auditLogs        AuditLog[]
  automationLogs   AutomationLog[]
  stageAutomationLogs StageAutomationLog[]
  knowledgeBases   KnowledgeBase[]
  aiAgents         AIAgent[]
  aiInsights       AIInsight[]
  aiTrainingData   AITrainingData[]
  agentLearningJobs AgentLearningJob[]
  messageTemplates MessageTemplate[]
  branches         Branch[]
  whiteLabelDomain WhiteLabelDomain?
  integrations     OrgIntegration[]
  comments         Comment[]
  notifications    Notification[]
  documents        Document[]
  documentTemplates DocumentTemplate[]
  achievements     Achievement[]
  goals            Goal[]
  leadScoringConfig LeadScoringConfig?
  zapierSubscriptions ZapierSubscription[]

  @@map("organizations")
}

// =============================================================================
// BRANCH (multi-filial placeholder)
// =============================================================================

model Branch {
  id              String   @id @default(cuid())
  name            String
  code            String?              // código da filial (ex: "SP-01", "RJ-02")
  address         String?
  phone           String?
  email           String?
  isActive        Boolean  @default(true)
  isHeadquarter   Boolean  @default(false)  // true = matriz
  settings        Json?                // configurações específicas da filial
  orgId           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users         User[]
  contacts      Contact[]
  deals         Deal[]
  conversations Conversation[]

  @@index([orgId])
  @@unique([orgId, code])
  @@map("branches")
}

// =============================================================================
// DEPARTMENT
// =============================================================================

model Department {
  id          String  @id @default(cuid())
  name        String
  description String?
  orgId       String

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users User[]

  @@index([orgId])
  @@map("departments")
}

// =============================================================================
// USER
// =============================================================================

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  email       String
  name        String
  avatar      String?
  role        UserRole @default(SELLER)
  orgId       String
  departmentId String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branchId     String?

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  branch       Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  deals        Deal[]        @relation("DealOwner")
  conversations Conversation[] @relation("ConversationAgent")
  activities   Activity[]
  messages     Message[]
  timelineEvents TimelineEvent[]
  auditLogs    AuditLog[]
  comments     Comment[]     @relation("CommentAuthor")
  notifications Notification[]
  achievements  Achievement[]
  goals         Goal[]

  @@index([orgId])
  @@index([email])
  @@index([branchId])
  @@map("users")
}

// =============================================================================
// CONTACT
// =============================================================================

model Contact {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  document     String?
  avatar       String?
  type         ContactType   @default(LEAD)
  source       ContactSource @default(MANUAL)
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  adId         String?
  adsetId      String?
  campaignId   String?
  pixelSessionId String?
  tags         String[]
  customFields Json          @default("{}")
  // Lead scoring
  leadScore        Int?
  leadTemperature  String?
  lastScoredAt     DateTime?
  scoreHistory     Json      @default("[]")
  orgId        String
  companyId    String?
  branchId     String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  deals         Deal[]
  conversations Conversation[]
  timeline      TimelineEvent[]
  activities    Activity[]
  payments      Payment[]
  automationLogs AutomationLog[]
  comments      Comment[]
  documents     Document[]

  @@index([orgId])
  @@index([email])
  @@index([phone])
  @@index([source])
  @@index([orgId, leadScore])
  @@map("contacts")
}

// =============================================================================
// COMPANY (B2B)
// =============================================================================

model Company {
  id       String  @id @default(cuid())
  name     String
  document String?
  website  String?
  segment  String?
  size     String?
  orgId    String

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts Contact[]

  @@index([orgId])
  @@map("companies")
}

// =============================================================================
// PIPELINE
// =============================================================================

model Pipeline {
  id          String  @id @default(cuid())
  name        String
  description String?
  color       String  @default("#7c5cfc")
  icon        String? // emoji ou nome de ícone

  // Contexto e propósito
  type        PipelineType
  context     Json?   // metadados livres: campanha, produto, serviço, etc.
  tags        String[]

  // Configuração
  isDefault        Boolean @default(false)
  isActive         Boolean @default(true)
  rotting          Boolean @default(true)   // ativar alerta de deals parados
  rottingDays      Int     @default(7)      // dias sem atividade = alerta
  currency         String  @default("BRL")
  winProbabilityAuto Boolean @default(true) // IA calcula probabilidade

  // Campos customizados específicos deste pipeline
  customFieldSchema Json @default("[]")
  // Estrutura: [{ key, label, type, required, options?, stage? }]

  // Permissões
  visibility   PipelineVisibility @default(ALL)
  allowedRoles String[]           @default([])

  orgId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org    Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stages PipelineStage[]
  deals  Deal[]

  @@index([orgId, isActive])
  @@map("pipelines")
}

model PipelineStage {
  id          String  @id @default(cuid())
  pipelineId  String
  name        String
  description String?
  order       Int
  color       String  @default("#7c5cfc")

  // Tipo da etapa
  type        StageType @default(REGULAR)

  // Probabilidade e métricas
  probability   Int     @default(0)  // 0-100%
  avgDaysInStage Float? // calculado automaticamente

  // Configuração de comportamento
  rottingDays   Int?    // override do pipeline, null = herda
  maxDeals      Int?    // limite de deals simultâneos nesta etapa

  // Automações da etapa — o que acontece ao entrar/sair/ficar parado
  onEnterActions   Json @default("[]") // ações ao entrar
  onExitActions    Json @default("[]") // ações ao sair
  onRottingActions Json @default("[]") // ações ao ficar parado
  requiredFields   Json @default("[]") // campos obrigatórios para sair

  // Integração com Super Agente
  agentId      String?  // agente ativado quando deal entra nesta etapa
  agentTrigger StageAgentTrigger @default(MANUAL)
  agentGoal    String?  // instrução específica para o agente nesta etapa

  // WON/LOST
  isWon  Boolean @default(false)
  isLost Boolean @default(false)

  pipelineId_rel Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade, map: "stage_pipeline_fk")
  agent          AIAgent? @relation(fields: [agentId], references: [id])
  deals          Deal[]
  fromMovements  DealStageMovement[] @relation("FromStage")
  toMovements    DealStageMovement[] @relation("ToStage")
  automationLogs StageAutomationLog[]

  @@index([pipelineId, order])
  @@map("pipeline_stages")
}

// =============================================================================
// DEAL
// =============================================================================

model Deal {
  id         String  @id @default(cuid())
  title      String
  value      Decimal @default(0) @db.Decimal(15, 2)
  currency   String  @default("BRL")

  // Pipeline e etapa
  pipelineId     String
  stageId        String
  stageEnteredAt DateTime @default(now()) // quando entrou no stage atual
  stageHistory   Json     @default("[]")  // histórico de movimentos

  // Contato e responsável
  contactId String
  ownerId   String
  orgId     String
  branchId  String?

  // Previsão
  probability     Int       @default(0)   // 0-100, calculado por IA ou manual
  aiProbability   Float?    // probabilidade calculada pela IA (separada)
  expectedCloseAt DateTime?
  closedAt        DateTime?
  closedReason    String?

  // Status de saúde
  isRotting      Boolean  @default(false)
  lastActivityAt DateTime @default(now())
  rottingDays    Int      @default(0)    // dias sem atividade

  // Campos customizados
  customFields Json @default("{}")

  // Integração com agente — quem está conduzindo este deal
  activeAgentSessionId String? // AIAgentSession ativa neste deal
  agentHistory         Json    @default("[]") // histórico de sessões de agente

  // Rastreio de origem
  utmSource   String?
  utmCampaign String?
  adId        String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipeline       Pipeline      @relation(fields: [pipelineId], references: [id])
  stage          PipelineStage @relation(fields: [stageId], references: [id])
  contact        Contact       @relation(fields: [contactId], references: [id])
  owner          User          @relation("DealOwner", fields: [ownerId], references: [id])
  org            Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  activities     Activity[]
  payments       Payment[]
  automationLogs AutomationLog[]
  stageAutomationLogs StageAutomationLog[]
  stageMovements DealStageMovement[]
  comments       Comment[]
  documents      Document[]

  @@index([orgId, pipelineId, stageId])
  @@index([orgId, ownerId])
  @@index([orgId, isRotting])
  @@index([contactId])
  // Supports the rotting sweep (`stageId, isActive, isRotting=false, lastActivityAt < threshold`).
  @@index([stageId, isActive, isRotting, lastActivityAt])
  @@map("deals")
}

// =============================================================================
// DEAL STAGE MOVEMENT
// =============================================================================

model DealStageMovement {
  id    String @id @default(cuid())
  dealId String
  orgId  String

  fromStageId   String?
  toStageId     String
  fromStageName String?
  toStageName   String

  // Quem/o que moveu
  movedBy        MovedByType
  userId         String?  // se movido por humano
  agentId        String?  // se movido por agente
  agentSessionId String?  // sessão do agente que moveu

  // Contexto da movimentação
  reason            String? // por que foi movido
  dataCollected     Json?   // dados coletados antes de mover
  triggerEvent      String? // evento que disparou (ex: "buying_signal_detected")

  // Tempo no stage anterior
  daysInPreviousStage Float?

  createdAt DateTime @default(now())

  deal      Deal           @relation(fields: [dealId], references: [id])
  fromStage PipelineStage? @relation("FromStage", fields: [fromStageId], references: [id])
  toStage   PipelineStage  @relation("ToStage", fields: [toStageId], references: [id])

  @@index([dealId])
  @@index([orgId, createdAt])
  @@map("deal_stage_movements")
}

// =============================================================================
// ACTIVITY
// =============================================================================

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String?
  dueAt       DateTime?
  completedAt DateTime?
  dealId      String?
  contactId   String?
  userId      String
  orgId       String

  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([dealId])
  @@index([contactId])
  @@index([userId])
  @@map("activities")
}

// =============================================================================
// CONVERSATION
// =============================================================================

model Conversation {
  id            String              @id @default(cuid())
  channel       ConversationChannel
  status        ConversationStatus  @default(OPEN)
  contactId     String
  orgId         String
  agentId       String?
  externalId    String?
  unreadCount   Int                 @default(0)
  lastMessageAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  branchId      String?

  contact    Contact      @relation(fields: [contactId], references: [id])
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agent      User?        @relation("ConversationAgent", fields: [agentId], references: [id], onDelete: SetNull)
  branch     Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  messages   Message[]
  aiSessions AIAgentSession[]

  @@unique([externalId, channel, orgId])
  @@index([orgId])
  @@index([contactId])
  @@index([status])
  @@map("conversations")
}

// =============================================================================
// MESSAGE
// =============================================================================

model Message {
  id             String           @id @default(cuid())
  content        String           @db.Text
  type           MessageType      @default(TEXT)
  direction      MessageDirection
  status         MessageStatus    @default(SENT)
  externalId     String?
  mediaUrl       String?
  mediaType      String?
  mediaSize      Int?
  conversationId String
  senderId       String?
  sentAt         DateTime         @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?
  metadata       Json             @default("{}")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@unique([conversationId, externalId], name: "messages_conversation_externalId_unique")
  @@index([conversationId])
  @@index([conversationId, sentAt])
  @@index([externalId])
  @@map("messages")
}

// =============================================================================
// MESSAGE TEMPLATE
// =============================================================================

model MessageTemplate {
  id       String @id @default(cuid())
  name     String
  category String
  language String @default("pt_BR")
  status   String @default("PENDING")
  header   Json?
  body     String @db.Text
  footer   String?
  buttons  Json?
  orgId    String

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("message_templates")
}

// =============================================================================
// PAYMENT
// =============================================================================

model Payment {
  id          String         @id @default(cuid())
  externalId  String?
  gateway     PaymentGateway
  type        PaymentType    @default(SINGLE)
  status      PaymentStatus  @default(PENDING)
  amount      Decimal        @db.Decimal(15, 2)
  currency    String         @default("BRL")
  description String?
  contactId   String?
  dealId      String?
  orgId       String
  paidAt      DateTime?
  dueAt       DateTime?
  expiresAt   DateTime?
  metadata    Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  contact Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal    Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([externalId])
  @@index([status])
  @@map("payments")
}

// =============================================================================
// WEBHOOK
// =============================================================================

model Webhook {
  id          String    @id @default(cuid())
  gateway     String
  event       String
  payload     Json
  status      String    @default("PENDING")
  attempts    Int       @default(0)
  processedAt DateTime?
  orgId       String?
  createdAt   DateTime  @default(now())

  org Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([gateway])
  @@index([status])
  @@map("webhooks")
}

// =============================================================================
// AUTOMATION
// =============================================================================

model Automation {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(false)
  orgId       String

  // Trigger
  triggerType   AutomationTriggerEnum @default(CONTACT_CREATED)
  triggerConfig Json  @default("{}")

  // Legacy fields kept for backward compat
  trigger     Json    @default("{}")
  conditions  Json    @default("[]")
  actions     Json    @default("[]")

  // Workflow graph nodes/edges
  nodes       Json    @default("[]")
  edges       Json    @default("[]")

  // Statistics
  executionCount Int       @default(0)
  lastExecutedAt DateTime?
  successCount   Int       @default(0)
  failureCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org  Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  logs AutomationLog[]

  @@index([orgId, isActive])
  @@map("automations")
}

model AutomationLog {
  id               String              @id @default(cuid())
  automationId     String
  contactId        String?
  dealId           String?
  conversationId   String?
  orgId            String
  status           String              // success | failed | skipped | partial
  triggerData      Json                @default("{}")
  nodesExecuted    Json                @default("[]")
  executedActions  Json                @default("[]")
  error            String?
  duration         Int?
  createdAt        DateTime            @default(now())

  automation Automation   @relation(fields: [automationId], references: [id], onDelete: Cascade)
  contact    Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal       Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([automationId, createdAt])
  @@index([contactId])
  @@index([orgId, createdAt])
  @@map("automation_logs")
}

model StageAutomationLog {
  id              String              @id @default(cuid())
  dealId          String
  stageId         String
  orgId           String
  ruleId          String
  ruleName        String
  trigger         String              // "enter" | "exit" | "rotting"
  status          AutomationLogStatus
  executedActions Json                @default("[]")
  error           String?
  /** BullMQ-job-scoped key used to no-op on retries after a worker crash. */
  idempotencyKey  String?             @unique
  createdAt       DateTime            @default(now())

  deal  Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stage PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  org   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
  @@index([stageId, createdAt])
  @@index([orgId, createdAt])
  @@map("stage_automation_logs")
}

// =============================================================================
// TIMELINE
// =============================================================================

model TimelineEvent {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String?
  metadata    Json     @default("{}")
  contactId   String
  userId      String?
  orgId       String
  createdAt   DateTime @default(now())

  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([orgId])
  @@map("timeline_events")
}

// =============================================================================
// AUDIT LOG
// =============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  resource   String
  resourceId String
  oldData    Json?
  newData    Json?
  userId     String?
  orgId      String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  org  Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// =============================================================================
// WHITE LABEL
// =============================================================================

model WhiteLabelDomain {
  id         String   @id @default(cuid())
  domain     String   @unique  // ex: "crm.agenciaxyz.com.br"
  isVerified Boolean  @default(false)
  orgId      String   @unique  // uma org = um domínio customizado
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@map("white_label_domains")
}

// =============================================================================
// KNOWLEDGE BASE
// =============================================================================

model KnowledgeBase {
  id          String            @id @default(cuid())
  name        String
  description String?
  type        KnowledgeBaseType
  orgId       String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  org       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  documents KnowledgeDocument[]

  @@index([orgId])
  @@map("knowledge_bases")
}

model KnowledgeDocument {
  id             String                       @id @default(cuid())
  title          String
  content        String                       @db.Text
  sourceUrl      String?
  sourceType     KnowledgeDocumentSourceType
  status         KnowledgeDocumentStatus      @default(PENDING)
  chunkCount     Int                          @default(0)
  metadata       Json                         @default("{}")
  knowledgeBaseId String
  orgId          String
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  knowledgeBase KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        KnowledgeChunk[]

  @@index([knowledgeBaseId])
  @@index([orgId])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id              String                  @id @default(cuid())
  content         String                  @db.Text
  chunkIndex      Int
  embeddingVector Unsupported("vector(1536)")?
  metadata        Json                    @default("{}")
  documentId      String
  orgId           String
  createdAt       DateTime                @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([orgId])
  @@map("knowledge_chunks")
}

// =============================================================================
// AI AGENT (Super Agent)
// =============================================================================

model AIAgent {
  id          String      @id @default(cuid())
  name        String
  description String?
  avatar      String?
  type        AgentType
  status      AgentStatus @default(DRAFT)
  phase       AgentPhase  @default(SETUP)

  // Provedor de IA
  provider AIProvider?
  model    String?

  // Configuração do super agente
  systemPrompt    String  @db.Text
  personality     Json    @default("{}")
  goal            String  @db.Text
  successCriteria Json    @default("{}")

  // Planejamento e fluxo
  flowTemplate  Json?
  decisionRules Json?
  requiredDataPoints Json @default("[]")

  // Configuração de comportamento
  maxTurnsBeforeHuman Int   @default(20)
  confidenceThreshold Float @default(0.75)
  temperature         Float @default(0.4)
  maxTokens           Int   @default(2048)

  // Ferramentas e conhecimento
  knowledgeBaseIds String[]
  enabledTools     Json @default("{}")
  handoffRules     Json @default("{}")

  // Aprendizado
  learningConfig        Json     @default("{}")
  learningCompletedAt   DateTime?
  learnedFromCount      Int      @default(0)
  minimumLearningSample Int      @default(30)

  orgId     String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org              Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions         AIAgentSession[]
  flowVersions     AgentFlowVersion[]
  learningJobs     AgentLearningJob[]
  stageAssignments PipelineStage[]

  @@index([orgId])
  @@map("ai_agents")
}

model AIAgentSession {
  id             String        @id @default(cuid())
  agentId        String
  conversationId String
  orgId          String

  // Estado da conversa
  intent           String?
  intentConfidence Float?
  currentStep      String?
  collectedData    Json    @default("{}")
  pendingQuestions Json    @default("[]")
  planSteps        Json    @default("[]")
  completedSteps   Json    @default("[]")

  // Controle
  status        SessionStatus @default(ACTIVE)
  turnCount     Int           @default(0)
  handoffReason String?
  handoffData   Json?

  // Resultado
  outcome      String?
  goalAchieved Boolean?

  startedAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())
  endedAt        DateTime?

  agent        AIAgent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  turns        AIAgentTurn[]

  @@index([agentId, status])
  @@index([conversationId])
  @@index([orgId])
  @@map("ai_agent_sessions")
}

model AIAgentTurn {
  id         String   @id @default(cuid())
  sessionId  String
  role       String   // user | assistant | tool
  content    String   @db.Text
  toolName   String?
  toolParams Json?
  toolResult String?  @db.Text
  tokensUsed Int      @default(0)
  createdAt  DateTime @default(now())

  session AIAgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("ai_agent_turns")
}

model AgentFlowVersion {
  id           String    @id @default(cuid())
  agentId      String
  version      Int
  flowTemplate Json
  notes        String?
  approvedBy   String?
  approvedAt   DateTime?
  isActive     Boolean   @default(false)
  createdAt    DateTime  @default(now())

  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, version])
  @@index([agentId])
  @@map("agent_flow_versions")
}

model AgentLearningJob {
  id              String    @id @default(cuid())
  agentId         String
  orgId           String
  status          String    @default("PENDING")
  conversationIds String[]
  analyzedCount   Int       @default(0)
  result          Json?
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([orgId])
  @@map("agent_learning_jobs")
}

// =============================================================================
// AI INSIGHT
// =============================================================================

model AIInsight {
  id                     String        @id @default(cuid())
  type                   AIInsightType
  title                  String
  content                String        @db.Text
  confidence             Float
  sourceConversationIds  String[]
  metadata               Json          @default("{}")
  orgId                  String
  createdAt              DateTime      @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([type])
  @@map("ai_insights")
}

// =============================================================================
// AI TRAINING DATA
// =============================================================================

model AITrainingData {
  id          String             @id @default(cuid())
  type        AITrainingDataType
  input       String             @db.Text
  output      String             @db.Text
  isValidated Boolean            @default(false)
  validatedBy String?
  orgId       String
  createdAt   DateTime           @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([type])
  @@map("ai_training_data")
}

// =============================================================================
// ORG INTEGRATION (Google Workspace, Slack, Notion, etc.)
// =============================================================================

model OrgIntegration {
  id           String    @id @default(cuid())
  orgId        String
  provider     String    // google_workspace | slack | notion | etc
  accessToken  String    @db.Text   // criptografado com AES-256-GCM
  refreshToken String?   @db.Text   // criptografado
  expiresAt    DateTime?
  scopes       String[]
  metadata     Json      @default("{}") // email da conta conectada, etc
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@index([orgId])
  @@map("org_integrations")
}

// =============================================================================
// LEAD SCORING
// =============================================================================

model LeadScoringConfig {
  id     String @id @default(cuid())
  orgId  String @unique
  isActive Boolean @default(true)

  demographicRules Json @default("[]")
  behavioralRules  Json @default("[]")

  aiScoringEnabled Boolean @default(true)
  aiWeight         Float   @default(0.4)

  hotThreshold  Int @default(80)
  warmThreshold Int @default(50)
  coldThreshold Int @default(0)

  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("lead_scoring_configs")
}

// =============================================================================
// COLLABORATION — COMMENTS
// =============================================================================

model Comment {
  id         String  @id @default(cuid())
  content    String  @db.Text
  mentions   String[]
  isResolved Boolean  @default(false)
  isInternal Boolean  @default(true)

  dealId         String?
  contactId      String?
  conversationId String?
  orgId          String
  authorId       String
  parentId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User         @relation("CommentAuthor", fields: [authorId], references: [id])
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal     Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact  Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  replies  Comment[]    @relation("CommentReplies")
  parent   Comment?     @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([dealId])
  @@index([contactId])
  @@index([orgId, createdAt])
  @@map("comments")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  orgId     String
  type      NotificationType
  title     String
  body      String
  metadata  Json             @default("{}")
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([orgId])
  @@map("notifications")
}

// =============================================================================
// DOCUMENTS
// =============================================================================

model Document {
  id          String         @id @default(cuid())
  name        String
  type        DocumentType
  status      DocumentStatus @default(DRAFT)

  fileUrl     String?
  fileSize    Int?
  mimeType    String?
  version     Int            @default(1)

  templateId  String?
  variables   Json           @default("{}")

  signers     Json           @default("[]")
  signedAt    DateTime?

  dealId      String?
  contactId   String?
  orgId       String
  createdById String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  deal     Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contact  Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  versions DocumentVersion[]

  @@index([orgId, type])
  @@index([dealId])
  @@map("documents")
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  version     Int
  fileUrl     String
  createdById String
  changes     String?
  createdAt   DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_versions")
}

model DocumentTemplate {
  id          String       @id @default(cuid())
  name        String
  description String?
  type        DocumentType
  content     String       @db.Text
  variables   Json         @default("[]")
  thumbnail   String?
  orgId       String
  isPublic    Boolean      @default(false)
  usageCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("document_templates")
}

// =============================================================================
// GAMIFICATION
// =============================================================================

model Achievement {
  id          String          @id @default(cuid())
  userId      String
  orgId       String
  type        AchievementType
  title       String
  description String
  icon        String
  points      Int
  unlockedAt  DateTime        @default(now())
  metadata    Json            @default("{}")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgId, type])
  @@map("achievements")
}

model Goal {
  id        String   @id @default(cuid())
  orgId     String
  userId    String?
  title     String
  metric    String
  target    Float
  current   Float    @default(0)
  period    String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)

  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isActive])
  @@map("goals")
}

// =============================================================================
// ZAPIER / MAKE.COM SUBSCRIPTIONS
// =============================================================================

model ZapierSubscription {
  id         String   @id @default(cuid())
  orgId      String
  event      String
  targetUrl  String
  provider   String   @default("zapier") // zapier | make
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, event])
  @@map("zapier_subscriptions")
}
